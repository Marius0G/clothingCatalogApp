# Copy to supabase/functions/.env for local `npx supabase functions serve`.
# In production set these with `npx supabase secrets set KEY=value`.
FEATHERLESS_API_KEY=
# Optional overrides (defaults: Featherless + Qwen2.5-VL-7B for vision, Llama-3.3-70B for text)
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# TEXT_MODEL=meta-llama/Llama-3.3-70B-Instruct
# VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# VISION_BASE_URL=
# VISION_API_KEY=
