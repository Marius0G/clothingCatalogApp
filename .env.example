# Copy to .env and fill in. EXPO_PUBLIC_* values are embedded in the app bundle (safe: anon key is public by design).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Doar pentru web servit printr-un tunel (ngrok): al doilea tunel către Supabase local (:54321).
# EXPO_PUBLIC_SUPABASE_URL_WEB=https://xxxx.ngrok-free.app

# Google Sign-In (Google Cloud Console → OAuth credentials)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=1234567890-xxxx.apps.googleusercontent.com
# Secretul clientului Web — citit de supabase/config.toml prin env() pentru stack-ul local
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=GOCSPX-xxxx
# Build-time only: reversed iOS client id
GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.1234567890-xxxx
